# ============================================================
# Hillsborough Probate Worker — Environment Variables
# Copy to .env and fill in values before running locally.
# On Railway: add these in the Railway dashboard Variables tab.
# ============================================================

# Supabase — same project as your Vercel app
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API key shared between Railway worker and Vercel app
# Generate any random string: openssl rand -hex 32
WORKER_API_KEY=your-random-api-key-here

# Port (Railway sets this automatically; set to 3001 locally)
PORT=3001

# Optional: set to "true" to run browser with visible UI (local debug only)
PLAYWRIGHT_HEADFUL=false
